# ---------------------------------------------------------------------------
# Project
# ---------------------------------------------------------------------------
PROJECT_NAME           = "bugbite"
PROJECT_BRIEF          = "Edge-ready smart relay for home appliance control"
OUTPUT_DIRECTORY       = docs

# ---------------------------------------------------------------------------
# Input
# ---------------------------------------------------------------------------
INPUT                  = src/ include/ README.md
FILE_PATTERNS          = *.cpp *.hpp *.md
RECURSIVE              = YES
EXCLUDE                = .pio/ lib/ test/
USE_MDFILE_AS_MAINPAGE = README.md

# ---------------------------------------------------------------------------
# Extraction
# ---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

# ---------------------------------------------------------------------------
# HTML output
# ---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

# Doxygen Awesome theme (cloned by the CI workflow before running doxygen)
HTML_EXTRA_STYLESHEET  = doxygen-awesome-css/doxygen-awesome.css
HTML_COLORSTYLE        = LIGHT
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

# ---------------------------------------------------------------------------
# Graphs (requires Graphviz)
# ---------------------------------------------------------------------------
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CLASS_GRAPH            = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_GRAPH_MAX_NODES    = 50

# ---------------------------------------------------------------------------
# Warnings
# ---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
